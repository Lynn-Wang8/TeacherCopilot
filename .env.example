# Teacher Copilot — 环境变量配置
# 复制此文件为 .env 并填入你的 Key
# cp .env.example .env

# ── AI 分类（纯文本）──
# DeepSeek（推荐，便宜 20 倍）: https://platform.deepseek.com/api_keys
# OpenAI: https://platform.openai.com/api-keys
AI_PROVIDER=deepseek
AI_API_KEY=sk-your-key-here
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com

# ── AI 识图（Vision / OCR）──
# 智谱 GLM-4V-Flash（免费）: https://open.bigmodel.cn/
# 阿里 Qwen-VL: https://dashscope.aliyun.com/
VISION_PROVIDER=glm
VISION_API_KEY=your-key-here
# VISION_MODEL=glm-4v-flash
